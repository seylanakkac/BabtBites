rules_version = '2';

// BabyBites Firestore güvenlik kuralları
// - Kullanıcılar yalnızca KENDİ verilerine erişir.
// - Ortak katalog (gıda/tarif/yazı/config) herkes tarafından okunur,
//   yalnızca admin e-postaları tarafından yazılır (token.email doğrulanmıştır).
//   (İleride custom claim'e (admin==true) geçilebilir.)
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['seylanakkac@gmail.com', 'admin@babybites.com'];
    }

    // Kullanıcıya özel veri: /users/{uid}/...
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Ortak katalog: /catalog/...
    match /catalog/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sosyal: tarif istatistikleri (puan/beğeni/görüntülenme).
    // Herkes okur; giriş yapmış kullanıcı aggregate'i günceller (MVP, istemciye güvenir).
    // Kendi oy/beğeni alt-dokümanını yalnızca sahibi yazar.
    match /recipeStats/{rid} {
      allow read: if true;
      allow write: if request.auth != null;
      match /{sub}/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Yorumlar: herkes okur; kullanıcı KENDİ yorumunu (onaysız) oluşturur;
    // admin (veya yorum sahibi) günceller/siler. Kullanıcı kendini onaylayamaz.
    match /recipeComments/{cid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false
        // Boyut sınırı: dev base64/metin ile Firestore'u zehirlemeyi önler.
        && (!('text' in request.resource.data) || request.resource.data.text.size() < 2000)
        && (!('photo' in request.resource.data) || request.resource.data.photo.size() < 2000);
      allow update, delete: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // Kullanıcı tarifleri (admin onay kuyruğu): admin tümünü okur; kullanıcı
    // kendi gönderdiğini görür/siler; herkes kendi onaysız tarifini oluşturur.
    match /pendingRecipes/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false;
      allow update, delete: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // Herkese açık kullanıcı profilleri: herkes okur, sahibi yazar.
    match /profiles/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Bildirimler: yalnızca alıcı okur/günceller (okundu işaretler); admin oluşturur.
    match /notifications/{id} {
      allow read, update: if request.auth != null && resource.data.toUid == request.auth.uid;
      allow create: if isAdmin();
      allow delete: if isAdmin() || (request.auth != null && resource.data.toUid == request.auth.uid);
    }

    // Onaylı uzmanlar: herkes okur (rozet/filtre), yalnız admin yazar.
    match /experts/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Uzman etiketi talepleri: kullanıcı kendi talebini oluşturur/görür/siler;
    // admin tümünü okur ve onaylar/siler (diploma no başkasınca okunamaz).
    match /expertRequests/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false;
      allow update, delete: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // Topluluk gönderileri: onaylananı herkes okur (admin/yazar onaysızı da okur).
    // Kullanıcı kendi onaysız gönderisini oluşturur (admin onayı şart).
    // Beğeni/anket/şikayet/yanıt sayacı için giriş yapmış kullanıcı günceller
    // (MVP, recipeStats ile aynı güven modeli) AMA 'approved' alanını yalnız admin
    // değiştirebilir → onay kapısı atlatılamaz. Silme: admin veya yazar.
    match /communityPosts/{id} {
      allow read: if resource.data.approved == true
        || isAdmin()
        || (request.auth != null && resource.data.authorUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.approved == false
        && request.resource.data.hidden == false
        && (!('title' in request.resource.data) || request.resource.data.title.size() < 300)
        && (!('body' in request.resource.data) || request.resource.data.body.size() < 8000);
      allow update: if request.auth != null
        && (request.resource.data.approved == resource.data.approved || isAdmin());
      allow delete: if isAdmin() || (request.auth != null && resource.data.authorUid == request.auth.uid);

      // Yanıtlar: herkes okur; kullanıcı kendi yanıtını oluşturur; güncelleme
      // (en iyi yanıt işareti) giriş yapmışa açık; silme admin veya yazar.
      match /replies/{rid} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.authorUid == request.auth.uid
          && (!('body' in request.resource.data) || request.resource.data.body.size() < 4000);
        allow update: if request.auth != null;
        allow delete: if isAdmin() || (request.auth != null && resource.data.authorUid == request.auth.uid);
      }
      // Beğeni: herkes okur; yalnız sahibi kendi beğenisini yazar.
      match /likes/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      // Şikayet: admin okur; yalnız sahibi kendi şikayetini yazar.
      match /reports/{uid} {
        allow read: if isAdmin();
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
