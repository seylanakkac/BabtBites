rules_version = '2';

// BabyBites Firestore güvenlik kuralları
// - Kullanıcılar yalnızca KENDİ verilerine erişir.
// - Ortak katalog (gıda/tarif/yazı/config) herkes tarafından okunur,
//   yalnızca admin e-postaları tarafından yazılır (token.email doğrulanmıştır).
//   (İleride custom claim'e (admin==true) geçilebilir.)
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['seylanakkac@gmail.com', 'admin@babybites.com'];
    }

    // Kullanıcıya özel veri: /users/{uid}/...
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Ortak katalog: /catalog/...
    match /catalog/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Sosyal: tarif istatistikleri (puan/beğeni/görüntülenme).
    // Herkes okur; giriş yapmış kullanıcı aggregate'i günceller (MVP, istemciye güvenir).
    // Kendi oy/beğeni alt-dokümanını yalnızca sahibi yazar.
    match /recipeStats/{rid} {
      allow read: if true;
      allow write: if request.auth != null;
      match /{sub}/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Yorumlar: herkes okur; kullanıcı KENDİ yorumunu (onaysız) oluşturur;
    // admin (veya yorum sahibi) günceller/siler. Kullanıcı kendini onaylayamaz.
    match /recipeComments/{cid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false;
      allow update, delete: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // Kullanıcı tarifleri (admin onay kuyruğu): admin tümünü okur; kullanıcı
    // kendi gönderdiğini görür/siler; herkes kendi onaysız tarifini oluşturur.
    match /pendingRecipes/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false;
      allow update, delete: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // Herkese açık kullanıcı profilleri: herkes okur, sahibi yazar.
    match /profiles/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Bildirimler: yalnızca alıcı okur/günceller (okundu işaretler); admin oluşturur.
    match /notifications/{id} {
      allow read, update: if request.auth != null && resource.data.toUid == request.auth.uid;
      allow create: if isAdmin();
      allow delete: if isAdmin() || (request.auth != null && resource.data.toUid == request.auth.uid);
    }

    // Onaylı uzmanlar: herkes okur (rozet/filtre), yalnız admin yazar.
    match /experts/{uid} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Uzman etiketi talepleri: kullanıcı kendi talebini oluşturur/görür/siler;
    // admin tümünü okur ve onaylar/siler (diploma no başkasınca okunamaz).
    match /expertRequests/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.approved == false;
      allow update, delete: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);
    }
  }
}
