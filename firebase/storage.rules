rules_version = '2';

// BabyBites Cloud Storage güvenlik kuralları
// - Kullanıcı fotoğrafları: yalnızca sahibi erişir.
// - Katalog görselleri: herkes okur, yalnızca admin yazar.
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['seylanakkac@gmail.com', 'admin@babybites.com'];
    }

    // Kullanıcı dosyaları (rapor PDF'leri vb.): yalnızca sahibi.
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Katalog görselleri: herkes okur, sadece admin yazar.
    match /catalog/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
