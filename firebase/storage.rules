rules_version = '2';

// BabyBites Cloud Storage güvenlik kuralları
// - Kullanıcı fotoğrafları: yalnızca sahibi erişir.
// - Katalog görselleri: herkes okur, yalnızca admin yazar.
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['seylanakkac@gmail.com', 'admin@babybites.com'];
    }

    // Yükleme boyut/tip sınırı (silmede request.resource null olur → izin verilir).
    function okUpload(maxBytes, typeRegex) {
      return request.resource == null
        || (request.resource.size < maxBytes && request.resource.contentType.matches(typeRegex));
    }

    // Kullanıcı dosyaları (rapor PDF'leri, yorum fotoğrafı): yalnızca sahibi, ≤10MB, görsel/pdf.
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && okUpload(10 * 1024 * 1024, 'image/.*|application/pdf');
    }

    // Katalog görselleri: herkes okur, sadece admin yazar; ≤10MB, sadece görsel.
    match /catalog/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && okUpload(10 * 1024 * 1024, 'image/.*');
    }
  }
}
